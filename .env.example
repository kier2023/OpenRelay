# Do NOT share your credentials with anyone.
# This file contains private API keys.

# -------------------------
# X (Twitter) API
# -------------------------

# Bearer token from your X developer app
X_BEARER_TOKEN=

# Your X user ID (NOT your @username)
X_USER_ID=

# Your X username
X_USERNAME=

# -------------------------
# Telegram Bot API
# -------------------------

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Chat or channel ID where tweets should be sent
# Example: -1001234567890
TELEGRAM_CHAT_ID=

# -------------------------
# Polling Configuration
# -------------------------

# Interval (milliseconds) to check for new tweets
# 60000 = 60 seconds
POLL_MS=60000