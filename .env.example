# Do NOT share your credentials with anyone.
# This file contains private API keys.

# -------------------------
# X (Twitter) API
# -------------------------

# Bearer token from your X developer app
X_BEARER_TOKEN=

# Your X user ID (NOT your @username)
X_USER_ID=

# Your X username
X_USERNAME=

# -------------------------
# Telegram Bot API
# -------------------------

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Chat or channel ID where tweets should be sent
# Example: -1001234567890
TELEGRAM_CHAT_ID=

# Telegram Admin Users
# Comma-separated list of Telegram user IDs allowed to run admin commands
TELEGRAM_ADMIN_IDS=

# -------------------------
# Discord Webhook Integration
# -------------------------

# Leave False if you don't want to integrate Discord.
# To enable change to "true".
DISCORD_ENABLED=false

# Webhook URL for the Discord channel where the tweet should be sent
DISCORD_WEBHOOK_URL=

# Discord Role ID (OPTIONAL) if you want to ping a role.
DISCORD_ROLE_ID=

# -------------------------
# Polling Configuration
# -------------------------

# Interval (milliseconds) to check for new tweets
# 60000 = 60 seconds
POLL_MS=60000